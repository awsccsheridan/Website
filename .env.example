# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# For localhost with production keys, add BOTH hostnames in Turnstile widget settings:
#   localhost
#   127.0.0.1
#
# If keys are omitted, dev uses Cloudflare interactive test keys (shows checkbox).
